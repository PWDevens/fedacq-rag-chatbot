    <node id="Tradeoff process">
      <data key="d0">Tradeoff process</data>
      <data key="d1">concept</data>
      <data key="d2">A process that involves considering factors other than the lowest price or highest technical rating when awarding contracts.</data>
      <data key="d3">doc-bbf1cc688706dd430bfe505423cb9745-chunk-000</data>
      <data key="d4">unknown_source</data>
