    <node id="Interests">
      <data key="d0">Interests</data>
      <data key="d3">doc-6eca0bd458a329d90a798631371e391f-chunk-000</data>
      <data key="d2">Encouraged exchanges of information among all interested parties to improve understanding of Government requirements and industry capabilities, thereby allowing potential offerors to judge whether or how they can satisfy the Government’s requirements, and enhancing the Government’s ability to obtain quality supplies and services, including construction, at reasonable prices, and increase efficiency in proposal preparation, proposal evaluation, negotiation, and contract award.</data>
      <data key="d1">UNKNOWN</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1782211946</data>
      <data key="d6" />
    </node>
