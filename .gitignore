# FAR/DFARS are cloned dynamically — do NOT track them
data/regs/far/
data/regs/dfars/

# Ignore Chroma runtime mutations only (NOT the committed index itself).
# data/chroma/** is tracked via Git LFS (see .gitattributes); the index —
# including chroma.sqlite3 and the segment .bin files — must be committed so
# clones can run without rebuilding.
data/chroma/*.wal
data/chroma/*.shm
data/chroma/*.lock

