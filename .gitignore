# ChromaDB runtime files (moved to data/chroma, keep root ignored)
/chroma/
test_chroma/
# FAR/DFARS are cloned dynamically — do NOT track them
data/regs/far/
data/regs/dfars/

# Ignore Chroma runtime mutations only (NOT the committed index itself).
# data/chroma/** is tracked via Git LFS (see .gitattributes); the index —
# including chroma.sqlite3 and the segment .bin files — must be committed so
# clones can run without rebuilding.
data/chroma/*.wal
data/chroma/*.shm
data/chroma/*.lock

# Writable runtime copy of the committed Chroma index. The app reads from this
# copy so query-time WAL checkpoints never dirty the LFS-tracked data/chroma.
data/chroma_runtime/

# Persistent exact-match answer cache (per-machine; not committed).
data/cache.db
data/cache.db-wal
data/cache.db-shm

# GraphRAG (LightRAG) artifacts: a prebuilt FAR Part 15 graph IS committed so
# `RAG_MODE=graph` works out of the box. Ignore only transient build logs.
data/lightrag/*.log

# Reports and Test Results
.coverage
.pipeline/**

# Internal session/handoff artifacts (not for public repo)
handoff.md
