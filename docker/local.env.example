# Environment variable template for local Docker deployment.
# Copy this file to docker/local.env and fill in real values.
# docker/local.env is gitignored and must never be committed.

# Required only when FLASK_ENV=production: Flask session signing key.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-random-secret-key

# Path inside the container to the Phi-4 ONNX model directory.
PHI4_MODEL_DIR=./cpu_and_mobile/cpu-int4-rtn-block-32-acc-level-4

# Path inside the container to the ChromaDB persistence directory.
CHROMA_PATH=./data/chroma

# Optional: HuggingFace API token for authenticated model downloads.
# Leave empty to use anonymous (rate-limited) access.
HF_TOKEN=

# Embedding model name. MUST match the model used to build the committed index.
EMBED_MODEL_NAME=BAAI/bge-small-en-v1.5

# Set to "production" to enable ProdConfig (disables DEBUG, requires SECRET_KEY).
# Use "local" for a quick local/Docker trial with the built-in dev key.
FLASK_ENV=local

# Optional: connect to a remote ChromaDB HTTP server instead of the on-disk index.
# Leave empty to use the default on-disk mode (recommended for local dev).
# CHROMA_HOST=
# CHROMA_PORT=8000
