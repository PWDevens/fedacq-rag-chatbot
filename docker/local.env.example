# Environment variable template for local Docker deployment.
# Copy this file to docker/local.env and fill in real values.
# docker/local.env is gitignored and must never be committed.

# Required: Flask session signing key. Use a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-with-a-random-secret-key

# Required: Path inside the container to the Phi-4 ONNX model directory.
PHI4_MODEL_DIR=./cpu_and_mobile/cpu-int4-rtn-block-32-acc-level-4

# Required: Path inside the container to the ChromaDB persistence directory.
CHROMA_PATH=./data/chroma

# Optional: HuggingFace API token for authenticated model downloads.
# Leave empty to use anonymous (rate-limited) access.
HF_TOKEN=

# Optional: HuggingFace embedding model name.
# Must match the model used when the Chroma index was built.
EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Optional: Set to "production" to enable ProdConfig (disables DEBUG).
FLASK_ENV=production
